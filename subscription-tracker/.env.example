# Test Environment Configuration

# Base URL for testing (default: http://localhost:5173)
BASE_URL=http://localhost:5173

# API URL for service testing (optional)
API_URL=http://localhost:5173

# Test environment: local, staging, production (default: local)
TEST_ENV=local

# CI flag (set automatically in CI environments)
CI=false

# Playwright Debug Mode (uncomment to debug)
# DEBUG=pw:api
